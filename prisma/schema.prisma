generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String     @id @default(uuid()) @db.VarChar(255)
  name           String?
  email          String?    @unique @db.VarChar(255)
  emailVerified  DateTime?
  hashedPassword String?
  role           String     @default("user") @db.VarChar(50)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  image          String?
  Account              Account[]
  contracts            Contract[]
  estimates            Estimate[]
  invoices             Invoice[]
  projects             Project[]
  appointments         Appointment[]
  aiEstimateSessions   AiEstimateSession[]
}

// ─── AI Estimate Sessions ─────────────────────────────────────────────────────
model AiEstimateSession {
  id              String   @id @default(uuid()) @db.VarChar(255)
  userId          String   @db.VarChar(255)
  // step: upload | scope | price | draft | saved | failed
  step            String   @default("upload") @db.VarChar(50)
  // job type: adu | service_upgrade | remodel | small_job | other
  jobType         String   @default("adu") @db.VarChar(50)
  // Raw text extracted from PDF/image by PlanParserAgent
  rawExtraction   String?
  // Structured scope confirmed by user (JSON)
  scope           String?
  // Priced line items approved by user (JSON)
  lineItems       String?
  // Final estimate draft (JSON)
  draft           String?
  // If saved, the resulting estimate ID
  savedEstimateId String?  @db.VarChar(255)
  // Rejection reason when bid not awarded (for analytics)
  rejectionReason String?  @db.VarChar(255)
  // Error message if an agent failed
  errorMessage    String?
  // Iteration counters per agent (JSON: {"parser":0,"scope":0,"price":0,"writer":0})
  iterations      String   @default("{}")
  // Original uploaded file name for reference
  fileName        String?  @db.VarChar(500)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([step])
  @@index([jobType])
  @@index([createdAt])
}

model Client {
  id        String     @id @default(uuid()) @db.VarChar(255)
  name      String     @db.VarChar(255)
  email     String     @db.VarChar(255)
  phone     String?    @db.VarChar(50)
  address   String?
  city      String?    @db.VarChar(100)
  state     String?    @db.VarChar(50)
  zipCode   String?    @db.VarChar(20)
  notes     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  contracts Contract[]
  estimates Estimate[]
  invoices  Invoice[]
  payments  Payment[]
  projects  Project[]
  appointments Appointment[]

  @@index([email])
}

model Project {
  id               String   @id @default(uuid()) @db.VarChar(255)
  clientId         String   @db.VarChar(255)
  userId           String   @db.VarChar(255)
  title            String   @db.VarChar(255)
  description      String?
  status           String   @default("active") @db.VarChar(50)
  sourceType       String   @default("estimate") @db.VarChar(50)
  sourceEstimateId String?  @unique @db.VarChar(255)
  sourceContractId String?  @unique @db.VarChar(255)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  client           Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id])

  @@index([clientId])
  @@index([userId])
  @@index([status])
  @@index([sourceType])
}

model AppointmentSlot {
  id          String       @id @default(uuid()) @db.VarChar(255)
  startTime   DateTime
  endTime     DateTime
  type        String       @default("any") @db.VarChar(50)
  isAvailable Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  appointment Appointment?

  @@index([startTime])
  @@index([isAvailable])
  @@index([type])
}

model Appointment {
  id           String           @id @default(uuid()) @db.VarChar(255)
  type         String           @default("estimate") @db.VarChar(50)
  status       String           @default("scheduled") @db.VarChar(50)
  startTime    DateTime
  endTime      DateTime
  clientId     String?          @db.VarChar(255)
  userId       String?          @db.VarChar(255)
  slotId       String?          @unique @db.VarChar(255)
  contactName  String?          @db.VarChar(255)
  contactEmail String?          @db.VarChar(255)
  contactPhone String?          @db.VarChar(50)
  address      String?
  notes        String?
  adminNotes   String?
  googleEventId String?         @db.VarChar(255)
  googleSyncStatus String?      @db.VarChar(50)
  googleSyncError String?
  googleSyncedAt DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  client       Client?          @relation(fields: [clientId], references: [id], onDelete: SetNull)
  user         User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  slot         AppointmentSlot? @relation(fields: [slotId], references: [id], onDelete: SetNull)

  @@index([startTime])
  @@index([status])
  @@index([type])
  @@index([clientId])
  @@index([userId])
  @@index([googleEventId])
}

model Estimate {
  id             String     @id @default(uuid()) @db.VarChar(255)
  estimateNumber String     @unique @db.VarChar(50)
  clientId       String     @db.VarChar(255)
  userId         String     @db.VarChar(255)
  title          String     @db.VarChar(255)
  description    String?
  items          String
  subtotal       Float
  tax            Float
  total          Float
  validUntil     DateTime?
  status         String     @default("draft") @db.VarChar(50)
  notes          String?
  sentAt         DateTime?
  viewedAt       DateTime?
  respondedAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  contract       Contract?
  emailLogs      EmailLog[]
  client         Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user           User       @relation(fields: [userId], references: [id])

  @@index([clientId])
  @@index([userId])
  @@index([status])
}

model Contract {
  id              String     @id @default(uuid()) @db.VarChar(255)
  contractNumber  String     @unique @db.VarChar(50)
  estimateId      String?    @unique @db.VarChar(255)
  clientId        String     @db.VarChar(255)
  userId          String     @db.VarChar(255)
  title           String     @db.VarChar(255)
  description     String?
  items           String
  phases          String?
  subtotal        Float
  tax             Float
  total           Float
  startDate       DateTime?
  completionDate  DateTime?
  status          String     @default("draft") @db.VarChar(50)
  terms           String?
  signedAt        DateTime?
  signedByClient  Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  paymentSchedule String?
  client          Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  estimate        Estimate?  @relation(fields: [estimateId], references: [id])
  user            User       @relation(fields: [userId], references: [id])
  emailLogs       EmailLog[]
  invoices        Invoice[]

  @@index([clientId])
  @@index([userId])
  @@index([estimateId])
  @@index([status])
}

model Invoice {
  id            String     @id @default(uuid()) @db.VarChar(255)
  invoiceNumber String     @unique @db.VarChar(50)
  contractId    String?    @db.VarChar(255)
  clientId      String     @db.VarChar(255)
  userId        String     @db.VarChar(255)
  title         String     @db.VarChar(255)
  description   String?
  items         String
  subtotal      Float
  tax           Float
  total         Float
  amountPaid    Float      @default(0)
  dueDate       DateTime?
  status        String     @default("draft") @db.VarChar(50)
  notes         String?
  sentAt        DateTime?
  paidAt        DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  emailLogs     EmailLog[]
  client        Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  contract      Contract?  @relation(fields: [contractId], references: [id])
  user          User       @relation(fields: [userId], references: [id])
  payments      Payment[]

  @@index([clientId])
  @@index([userId])
  @@index([contractId])
  @@index([status])
}

model Payment {
  id              String   @id @default(uuid()) @db.VarChar(255)
  invoiceId       String   @db.VarChar(255)
  clientId        String   @db.VarChar(255)
  amount          Float
  paymentMethod   String   @db.VarChar(50)
  paymentDate     DateTime
  referenceNumber String?  @db.VarChar(100)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  invoice         Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([clientId])
}

model EmailLog {
  id           String    @id @default(uuid()) @db.VarChar(255)
  estimateId   String?   @db.VarChar(255)
  contractId   String?   @db.VarChar(255)
  invoiceId    String?   @db.VarChar(255)
  recipient    String    @db.VarChar(255)
  subject      String    @db.VarChar(500)
  body         String
  status       String    @db.VarChar(50)
  sentAt       DateTime  @default(now())
  errorMessage String?
  contract     Contract? @relation(fields: [contractId], references: [id])
  estimate     Estimate? @relation(fields: [estimateId], references: [id])
  invoice      Invoice?  @relation(fields: [invoiceId], references: [id])

  @@index([estimateId])
  @@index([contractId])
  @@index([invoiceId])
}

model Account {
  id                String  @id @db.VarChar(255)
  userId            String  @db.VarChar(255)
  type              String
  provider          String  @db.VarChar(255)
  providerAccountId String  @db.VarChar(255)
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  User              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}
